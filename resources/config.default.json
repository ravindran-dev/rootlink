{
  "theme": "dark",
  "animations_enabled": true,
  "blur_enabled": true,
  "animation_speed": 0.8,
  "default_view": "grid",
  "show_hidden_files": false,
  "show_file_extensions": true,
  "single_click_open": false,
  "confirm_delete": true,
  "trash_enabled": true,
  "sidebar_width": 250,
  "remember_window_size": true,
  "remember_sort_order": true,
  "sort_by": "name",
  "sort_ascending": true,
  "thumbnail_size": 96,
  "enable_search_indexing": true,
  "max_search_results": 100,
  "recent_files_count": 20,
  "favorite_paths": [
    "~/Desktop",
    "~/Documents",
    "~/Downloads",
    "~/Pictures"
  ],
  "keyboard_shortcuts": {
    "grid_view": "Ctrl+1",
    "list_view": "Ctrl+2",
    "column_view": "Ctrl+3",
    "search": "Ctrl+F",
    "copy": "Ctrl+C",
    "paste": "Ctrl+V",
    "cut": "Ctrl+X",
    "select_all": "Ctrl+A",
    "delete": "Delete",
    "new_folder": "Ctrl+Shift+N",
    "new_window": "Ctrl+N",
    "new_tab": "Ctrl+T",
    "close_tab": "Ctrl+W",
    "preferences": "Ctrl+Comma",
    "quick_look": "Space",
    "toggle_hidden": "Ctrl+H"
  }
}
